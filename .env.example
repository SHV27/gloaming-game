# GLOAMING — environment template. Copy to `.env` (gitignored) and fill in.
# The narrator key is used ONLY by the server-side /api/narrate function — it
# must never reach the browser bundle (CLAUDE.md §8). The game is fully playable
# with NO key: the Living Narrator silently falls back to the hand-authored deck.

# Google Gemini API key (free tier) for the Living Narrator. Optional.
GEMINI_API_KEY=
